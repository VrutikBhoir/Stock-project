{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Run Backend API 8001",
			"type": "shell",
			"command": "backend\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"uvicorn",
				"app.main:app",
				"--app-dir",
				"backend",
				"--host",
				"127.0.0.1",
				"--port",
				"8001",
				"--reload"
			],
			"isBackground": true
		},
		{
			"label": "Run Backend API 8001 (app-dir)",
			"type": "shell",
			"command": "backend\\.venv\\Scripts\\python.exe",
			"args": [
				"-m",
				"uvicorn",
				"app.main:app",
				"--app-dir",
				"backend",
				"--host",
				"127.0.0.1",
				"--port",
				"8001",
				"--reload"
			],
			"isBackground": true
		}
	]
}